{
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.karaokemultiplayer.com.br"
        }
      ],
      "destination": "https://karaokemultiplayer.com.br/$1",
      "permanent": true
    }
  ]
}
